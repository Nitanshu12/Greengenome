# Copy to .env and fill in values. Never commit .env.

PORT=4000
NODE_ENV=production

# MongoDB Atlas — include database name before ? e.g. ...mongodb.net/dashboard?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dashboard?retryWrites=true&w=majority

SESSION_SECRET=use-a-long-random-string-in-production

# Comma-separated browser origins allowed to call the API with cookies (only if frontend is on another domain).
# Leave unset for single-origin (React build served by this app on Render).
# Example: https://my-app.vercel.app
# ALLOWED_ORIGINS=

# Only if frontend is on a different site than the API (e.g. Vercel + Render): set to "none" and set ALLOWED_ORIGINS.
# SESSION_COOKIE_SAMESITE=lax

# TRUST_PROXY=false
