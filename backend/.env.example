# Copy to .env and fill in values. Never commit .env.

PORT=4000
NODE_ENV=production

# MongoDB Atlas — include database name before ? e.g. ...mongodb.net/dashboard?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dashboard?retryWrites=true&w=majority

SESSION_SECRET=use-a-long-random-string-in-production

# --- Vercel UI + Render API (split deploy) — set on Render (either works): ---
# FRONTEND_URL=https://greengenome.vercel.app
#   or comma-separated: ALLOWED_ORIGINS=https://greengenome.vercel.app
# If FRONTEND_URL / ALLOWED_ORIGINS is set, session cookies use SameSite=None automatically in production.
# Optional override: SESSION_COOKIE_SAMESITE=none
# Frontend build: VITE_API_BASE_URL=https://your-service.onrender.com

# Single-origin (React build served by this Node app only): leave ALLOWED_ORIGINS unset.
# ALLOWED_ORIGINS=

# SESSION_COOKIE_SAMESITE=lax

# TRUST_PROXY=false
